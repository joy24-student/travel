{
  "expo": {
    "name": "Converted Travel UI",
    "slug": "converted-travel-ui",
    "version": "1.0.0",
    "scheme": "converted-travel-ui",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-build-properties",
        {
          "buildReactNativeFromSource": true
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      ["expo-facebook", { "userTrackingPermission": false }]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "NSCameraUsageDescription": "This app uses the camera to scan QR codes and capture images for your profile.",
        "NSPhotoLibraryUsageDescription": "This app uses the photo library to select images for your profile."
      }
    },
    "android": {
      "package": "com.s025.convertedtravelui",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    }
  }
}
