{
  "expo": {
    "name": "Converted Travel UI",
    "slug": "converted-travel-ui",
    "version": "1.0.0",
    "scheme": "converted-travel-ui",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-build-properties",
        {
          "buildReactNativeFromSource": true
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      ["expo-facebook", { "userTrackingPermission": false }]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.s025.convertedtravelui",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}
